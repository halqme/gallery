<button
  id="theme-toggle"
  class="btn-ghost before:content-empty before:text-md p-2"
  aria-label="テーマを切り替え: 現在は自動"
>
</button>

{/* ライブリージョン for スクリーンリーダー */}
<div role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

<style>
  :global(html[data-theme="auto"]) #theme-toggle {
    --at-apply: "before:i-lucide:monitor";
  }
  :global(html[data-theme="light"]) #theme-toggle {
    --at-apply: "before:i-lucide:sun";
  }
  :global(html[data-theme="dark"]) #theme-toggle {
    --at-apply: "before:i-lucide:moon";
  }
</style>

<script is:inline>
  (() => {
    const NOTIFICATION_DURATION_MS = 2000;

    function getTheme() {
      if (
        typeof localStorage !== "undefined" &&
        localStorage.getItem("theme")
      ) {
        return localStorage.getItem("theme");
      }
      return "auto";
    }

    const applyTheme = (theme, announce = false) => {
      const isDark =
        theme === "dark" ||
        (theme === "auto" &&
          window.matchMedia("(prefers-color-scheme: dark)").matches);

      document.documentElement.classList.toggle("dark", isDark);
      document.documentElement.setAttribute("data-theme", theme);

      const button = document.getElementById("theme-toggle");
      if (button) {
        const labels = {
          auto: "自動",
          dark: "ダークモード",
          light: "ライトモード",
        };
        button.setAttribute(
          "aria-label",
          `テーマを切り替え: 現在は${labels[theme]}`,
        );

        // ライブリージョンに通知
        if (announce) {
          const liveRegion = button.nextElementSibling;
          if (liveRegion && liveRegion.getAttribute("role") === "status") {
            liveRegion.textContent = `テーマを${labels[theme]}に変更しました`;
            setTimeout(() => {
              liveRegion.textContent = "";
            }, NOTIFICATION_DURATION_MS);
          }
        }
      }
    };

    applyTheme(getTheme(), false);

    const setupButton = () => {
      const button = document.getElementById("theme-toggle");
      if (button) {
        if (button.hasAttribute("data-theme-initialized")) {
          return;
        }
        button.setAttribute("data-theme-initialized", "true");

        button.addEventListener("click", () => {
          const current = getTheme();
          const next =
            current === "auto" ? "dark" : current === "dark" ? "light" : "auto";
          localStorage.setItem("theme", next);
          applyTheme(next, true);
        });
        applyTheme(getTheme(), false);
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupButton);
    } else {
      setupButton();
    }

    document.addEventListener("astro:page-load", setupButton);

    document.addEventListener("astro:before-swap", (e) => {
      e.newDocument.documentElement.className =
        document.documentElement.className;
      e.newDocument.documentElement.setAttribute(
        "data-theme",
        document.documentElement.getAttribute("data-theme") || "auto",
      );
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        if (getTheme() === "auto") {
          applyTheme("auto", false);
        }
      });
  })();
</script>
