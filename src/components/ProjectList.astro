---
const projects = [
  {
    description: "Markdownでスライドを作成できるBun製ツール",
    name: "slide_bun",
    tech: ["TypeScript", "Bun"],
    url: "https://github.com/HALQME/slide_bun",
  },
  {
    description: "Bun向けの宣言的TUIフレームワーク",
    name: "btuin",
    tech: ["TypeScript", "Bun"],
    url: "https://github.com/HALQME/btuin",
  },
  {
    description: "Apple Foundation Models用CLIチャットツール",
    name: "Fai",
    tech: ["Swift"],
    url: "https://github.com/HALQME/Fai",
  },
  {
    description: "大阪公立大学合氣道部の稽古管理アプリ",
    name: "omu-aikido-app",
    tech: ["TypeScript", "Hono", "Vue.js"],
    url: "https://github.com/omu-aikido/omu-aikido-app",
  },
];
---

<section class="section" aria-labelledby="projects-title">
  <h2
    id="projects-title"
    class="text-headline mb-8 flex items-center gap-3 select-none"
  >
    <span class="i-lucide:folder-git-2"></span>
    Projects
  </h2>
  <div class="grid-responsive">
    {
      projects.map((project) => (
        <div class="card-interactive card-content group relative flex flex-col p-4">
          <h3 class="text-subhead mb-2 flex items-center justify-between">
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="decoration-2 underline-offset-4 group-hover:underline"
            >
              <span class="absolute inset-0 z-10" aria-hidden="true" />
              {project.name}
            </a>
            <span class="i-lucide:external-link text-sm opacity-50 hidden group-hover:block" />
          </h3>
          <p class="text-body mb-2 flex-1">{project.description}</p>
          <ul class="flex flex-wrap items-center gap-2 select-none">
            {project.tech.map((t) => (
              <li class="tag text-xs">{t}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
