---
import { Font } from "astro:assets";

import ThemeToggle from "../components/ThemeToggle.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "gallery", description = "アプリケーションギャラリー" } =
  Astro.props;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-ia-writer-mono" preload />
    <Font cssVariable="--font-shippori-antique" preload />
  </head>
  <body
    class="pattern-dots bg-base flex min-h-screen flex-col font-sans text-base selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black"
  >
    <header class="header">
      <nav class="flex items-center gap-6">
        <a href="https://0w0.foo" class="link-nav font-mono flex items-center gap-1.5">
          <span class="i-lucide:arrow-left text-xs opacity-70"></span>
          0w0.foo
        </a>
      </nav>
      <div class="header-actions">
        <ThemeToggle />
      </div>
    </header>
    <main id="main-content" class="container-main w-full flex-1 py-6 md:py-20">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  /* ===== Header ===== */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
    user-select: none;
  }

  @media (min-width: 768px) {
    .header {
      padding: 0 3rem;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
