{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gallery",
  "compatibility_date": "2026-05-09",
  "assets": {
    "not_found_handling": "404-page",
    "directory": "dist",
  },
  "compatibility_flags": ["nodejs_compat"],
  "route": {
    "custom_domain": true,
    "pattern": "apps.0w0.foo",
  },
  "placement": { "mode": "smart" },
}
